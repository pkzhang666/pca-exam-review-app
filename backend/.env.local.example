# Copy to .env.local for local development. Loaded automatically by the server.
# This config needs NO GCP project, NO Firebase, and NO Anthropic key.

PORT=8080
GOOGLE_CLOUD_PROJECT=local-dev
LOCATION=us-central1
UPLOAD_BUCKET=local-uploads
TASKS_QUEUE=deck-generation

# Point the Google SDKs at the local emulators (docker compose up)
FIRESTORE_EMULATOR_HOST=localhost:8085
STORAGE_EMULATOR_HOST=http://localhost:4443

# Local-mode switches
DEV_AUTH=true              # skip Firebase; requests are authed via X-Dev-Email header
MOCK_GENERATION=true       # canned questions instead of calling Claude (free, offline)
USE_CLOUD_TASKS=false      # run generation in-process instead of via Cloud Tasks

# CORS for the Vite dev server
ALLOWED_ORIGINS=http://localhost:5173

# Secrets are unused under DEV_AUTH + MOCK_GENERATION, but keep TASK_SECRET set.
TASK_SECRET=local-dev-secret

# LLM keys — leave both empty while MOCK_GENERATION=true. To test REAL
# generation, set MOCK_GENERATION=false and provide ONE key below. The provider
# is auto-detected from whichever key is set (Gemini preferred if both).
GEMINI_API_KEY=
ANTHROPIC_API_KEY=
# LLM_PROVIDER=gemini          # optional: force "gemini" or "anthropic"
# GEMINI_MODEL=gemini-2.5-flash
# MODEL=claude-opus-4-8        # Anthropic model, if using anthropic

# Small caps so you can hit them while testing
PER_USER_DAILY_CAP=50
DAILY_DECK_CAP=100
