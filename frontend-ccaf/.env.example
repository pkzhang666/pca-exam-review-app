# Frontend config. Copy to .env.local (gitignored) to override defaults.
# Defaults work out of the box against a local backend in DEV_AUTH mode.

# Backend base URL
VITE_API_BASE=http://localhost:8080

# Local dev only: which user the backend's DEV_AUTH should treat you as.
# (In production this is replaced by Firebase sign-in; see backend/README.md.)
VITE_DEV_EMAIL=me@example.com
